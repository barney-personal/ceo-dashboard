# ============================================================
# Environment Variables
# ============================================================
# Managed via Doppler. This file is for reference only.
# Run: doppler run -- npm run dev
#
# NEVER commit .env to git. It is in .gitignore.
# ============================================================

# --- Clerk Auth ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Database ---
# DATABASE_URL=postgresql://user:pass@host:5432/ceo_dashboard

# --- Mode Analytics (Active) ---
# MODE_API_TOKEN=
# MODE_API_SECRET=
# MODE_WORKSPACE=cleoai

# --- Slack (Active — OKR sync + management accounts) ---
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_OKR_CHANNEL_IDS=C01234,C56789

# --- Anthropic (Active — OKR parsing + Excel extraction) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- Cron (auto-generated on Render) ---
# CRON_SECRET=

# --- Meetings (Granola + Slack Pre-reads) ---
# Google Calendar uses per-user Clerk OAuth tokens (no env vars needed)
# GRANOLA_API_TOKEN=grn_...               # From Granola desktop app: Settings > API > Create new key
# SLACK_PRE_READS_CHANNEL_ID=C01234       # Channel ID for #pre-reads

# --- GitHub (Active — Engineering PR metrics) ---
# GITHUB_API_TOKEN=ghp_...          # PAT with repo + read:org scopes
# GITHUB_ORG=your-org               # GitHub org to track

# --- HiBob (Planned) ---
# HIBOB_API_TOKEN=
# HIBOB_SERVICE_USER_ID=

# --- Notion (Planned) ---
# NOTION_API_TOKEN=secret_...
# NOTION_OKR_DATABASE_IDS=abc123,def456

# --- Culture Amp (Planned) ---
# CULTUREAMP_API_KEY=
